{
  "name": "nhatro-be",
  "version": "0.0.1",
  "description": "Backend for nhatro",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:debug": "node --inspect-brk -r tsconfig-paths/register dist/main.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@nestjs/platform-express": "11.1.17",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.17",
    "typescript": "6.0.2",
    "ts-node": "10.9.2",
    "@types/node": "25.5.0",
    "prettier": "3.8.1"
  }
}
